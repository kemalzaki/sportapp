{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "watchPatterns": ["Dockerfile", "**/*.php"]
  },
  "deploy": {
    "startCommand": "apache2-foreground",
    "restartPolicyType": "ON_FAILURE",
    "healthCheckPath": "/",
    "healthCheckTimeout": 100
  }
}