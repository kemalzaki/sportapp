# Disable directory indexing for security
Options -Indexes

# Prevent access to config and includes directories
RewriteEngine On
RewriteRule ^(config|includes)/ - [F,L]

# Prevent access to database dumps, configuration files and credentials
<FilesMatch "\.(sql|yaml|json|jsonl|md|git|gitignore)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>
