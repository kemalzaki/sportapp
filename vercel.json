{
  "functions": {
    "*.php": {
      "runtime": "vercel-php@0.6.0"
    },
    "admin/*.php": {
      "runtime": "vercel-php@0.6.0"
    }
  },
  "routes": [
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/admin/(.*\\.php)", "dest": "/admin/$1" },
    { "src": "/(.*\\.php)", "dest": "/$1" },
    { "src": "/(.*)", "dest": "/index.php" }
  ]
}
